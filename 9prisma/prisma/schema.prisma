// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "mysql"
}

model User {
    id    Int     @id @default(autoincrement()) // 主键，自增
    email String  @unique // 唯一索引
    name  String? // 姓名
    posts Post[] // 关联的文章，一对多关系
}

model Post {
    id        Int     @id @default(autoincrement()) // 主键，自增
    title     String  // 标题
    content   String? @db.Text // 内容，文本类型
    published Boolean @default(false) // 是否发布，默认值为 false
    author    User    @relation(fields: [authorId], references: [id]) // 作者，关联 User 模型的 id 字段
    authorId  Int // 作者 id，外键引用 User 模型的 id 字段
}
